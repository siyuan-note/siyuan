					"TextMarkTextContent": "}}"
				},
				{
					"Type": "NodeText",
					"Data": " to wrap SQL scripts on a single line: "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "{{ SELECT * FROM blocks WHERE content LIKE'%Keyword%' }}"
				},
				{
					"Type": "NodeText",
