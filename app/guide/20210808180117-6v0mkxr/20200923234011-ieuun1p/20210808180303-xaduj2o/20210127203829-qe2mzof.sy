				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Annotations support 7 preset colors. Annotation data is automatically saved as a "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": ".sya"
				},
				{
					"Type": "NodeText",
					"Data": "​ file with the same name as the PDF, stored in the same directory as the PDF."
				}
			]
		},
