							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Copy to Document"
								},
								{
									"Type": "NodeText",
									"Data": ": After creating an annotation, the reference text is in the format "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "code",
									"TextMarkTextContent": "\u0026lt;\u0026lt;assets/xxx.pdf/annotationID \"selected text\"\u0026gt;\u0026gt;"
								},
								{
									"Type": "NodeText",
									"Data": "​ and can be pasted directly into a document as a reference link. Area annotations also include a screenshot of the annotated region when copied"
