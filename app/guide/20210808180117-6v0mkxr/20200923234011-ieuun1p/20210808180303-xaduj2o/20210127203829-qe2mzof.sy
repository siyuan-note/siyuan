							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Rectangular Area Annotation"
								},
								{
									"Type": "NodeText",
									"Data": ": Click the area annotation button in the PDF toolbar, then drag to draw a rectangle on the PDF page. Two styles are supported: filled rectangle (with background color) and border rectangle (border only), switchable via the style toggle button in the annotation menu"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20260614112546-ubmknif",
