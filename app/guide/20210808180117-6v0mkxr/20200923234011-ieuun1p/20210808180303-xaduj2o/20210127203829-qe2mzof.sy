			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Overview"
				}
			]
		},
		{
			"ID": "20260614112546-rvdkkuo",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112546-rvdkkuo",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan supports PDF file preview and annotation. You can mark up text or areas in a PDF and copy annotation references into documents, enabling two-way linking between literature reading and note writing."
				}
			]
		},
		{
			"ID": "20260614112546-0nfcwzb",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112546-0nfcwzb",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Inserting a PDF Asset"
				}
			]
		},
		{
			"ID": "20260614112546-9iv29eu",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112546-9iv29eu",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "After uploading and inserting a PDF file through the editor, the PDF is placed in the assets folder and a link in the format "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf)"
				},
				{
					"Type": "NodeText",
					"Data": "​ is generated in the document. Click the link to preview the PDF in SiYuan."
				}
			]
		},
		{
			"ID": "20260614112546-2o5u1qw",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112546-2o5u1qw",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Hyperlink Page Jump"
				}
			]
		},
		{
			"ID": "20260614112546-umprdds",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112546-umprdds",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "When opening a PDF preview in a new tab, you can specify a page number by adding the "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "page"
				},
				{
					"Type": "NodeText",
					"Data": "​ parameter to the link. For example, to jump to page 7, edit the link to "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf?page=7)"
				},
				{
					"Type": "NodeText",
					"Data": "​."
				}
			]
		},
		{
			"ID": "20260614112546-arf81wv",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112546-arf81wv",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Annotation"
				}
			]
		},
		{
			"ID": "20260614112546-m9odbls",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112546-m9odbls",
				"updated": "20260614112546"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Annotate text or areas in the PDF preview and copy annotation references into documents for seamless integration between reading and note-taking."
				}
			]
		},
