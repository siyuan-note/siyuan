							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Text Selection Highlight"
								},
								{
									"Type": "NodeText",
									"Data": ": Select text in the PDF, choose a color from the popup toolbar, and a semi-transparent highlight is added. The annotation reference text is automatically copied to the clipboard and can be pasted directly into a document as a reference link"
								}
							]
						}
					]
				},
