		{
			"ID": "20260614194307-s247j6d",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614194307-s247j6d",
				"updated": "20260614194307"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "After revealing the answer, Space and Enter also trigger the \"Good\" rating. Ratings directly affect the review interval for each card — higher ratings extend the time before the next review, and lower ratings shorten it. The system uses the FSRS algorithm to automatically optimize each user's review schedule based on their rating history."
				}
			]
		},
		{
