		{
			"ID": "20260614194307-wa1h7dm",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614194307-wa1h7dm",
				"updated": "20260614194307"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Once a content block is set as a flashcard, the system automatically schedules reviews using the FSRS spaced repetition algorithm (github repo: open-spaced-repetition/free-spaced-repetition-scheduler), prompting reviews at the point of forgetting to help convert short-term memory into long-term memory."
				}
			]
		},
		{
			"ID": "20260614194307-zktvfds",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
