					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan [global flags] \u0026lt;command\u0026gt; [parameters]"
				},
				{
					"Type": "NodeText",
					"Data": "​"
				}
