			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260618124055-7xuwk04",
				"updated": "20260618124055"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan ships with a built-in CLI (Command Line Interface) that accesses workspace data directly, with no need to start the kernel server. It is well suited for scripting, batch management, and read/write operations on notes in conjunction with AI agents."
				}
			]
		},
		{
			"ID": "20260618124055-b5vmv3w",
			"Type": "NodeParagraph",
			"Properties": {
