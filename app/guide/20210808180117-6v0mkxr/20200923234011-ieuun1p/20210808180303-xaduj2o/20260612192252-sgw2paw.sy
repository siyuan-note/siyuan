					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "siyuan search \"keyword\" --asset\nsiyuan search \"keyword\" --asset --ext pdf --ext docx\nsiyuan search \"keyword\" --asset --method 3 --order-by 3\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
