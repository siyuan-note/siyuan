				"updated": "20260618124055"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan [global flags] &lt;command&gt; [arguments]"
				},
				{
					"Type": "NodeText",
					"Data": "​"
				}
			]
		},
