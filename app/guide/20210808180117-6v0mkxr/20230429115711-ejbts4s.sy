							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Export preview: preview after conversion to standard Markdown"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20230429115912-zd5p7jl",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115912-zd5p7jl",
				"updated": "20250115163213"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "WYSIWYG and export preview mode switches are located in the "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ menu in the upper right corner of the editor; WYSIWYG editing and read-only mode switches are located in the upper right corner of the top bar."
				}
			]
		},
		{
			"ID": "20260614111229-to99h4r",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111229-to99h4r",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Block Reference"
				}
			]
		},
		{
			"ID": "20260614111229-2ogahww",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111229-2ogahww",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111229-vob22z9",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111229-vob22z9",
						"updated": "20260614111229"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A reference is a link pointing to another piece of content, allowing the reader to jump to the referenced location."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111229-pgtjgxi",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111229-pgtjgxi",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, a block reference is a link triggered by "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "(("
				},
				{
					"Type": "NodeText",
					"Data": "​ that points to another content block. It supports both static anchor text and dynamic anchor text. Clicking a block reference navigates to the referenced block; hovering shows a preview."
				}
			]
		},
		{
			"ID": "20260614111229-mp4whcc",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111229-mp4whcc",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Backlink"
				}
			]
		},
		{
			"ID": "20260614111229-9spl9ve",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111229-9spl9ve",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111229-98p3e3u",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111229-98p3e3u",
						"updated": "20260614111229"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A backlink is a link from another page pointing to the current page, an essential component of a bidirectional linking system."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111229-7mco34k",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111229-7mco34k",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, the backlink panel displays all blocks that reference the current block. Backlinks are divided into two parts: links (directly connected via block references) and mentions (potential connections matched by text)."
				}
			]
		},
		{
			"ID": "20260614111229-to1iuj1",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111229-to1iuj1",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Mention"
				}
			]
		},
		{
			"ID": "20260614111229-sfctxyi",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111229-sfctxyi",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111229-qsw7m2s",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111229-qsw7m2s",
						"updated": "20260614111229"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A mention is a keyword match found in text, used to discover potential connections."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111229-71ipyls",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111229-71ipyls",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, mentions are similar to the links part of backlinks, but instead of being established through block references, they are automatically matched text content found by searching content block names, aliases, and reference anchor text. Mentions can be converted to block references with one click."
				}
			]
		},
		{
			"ID": "20260614111229-xhhdmql",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111229-xhhdmql",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Virtual Reference"
				}
			]
		},
		{
			"ID": "20260614111229-4gfb4hy",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111229-4gfb4hy",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111229-pg7ejry",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111229-pg7ejry",
						"updated": "20260614111229"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A virtual reference is a technique for automatically discovering potential reference relationships, identifying content blocks that may be related without manual creation."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111229-2a1poix",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111229-2a1poix",
				"updated": "20260614111229"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, virtual references automatically detect potential connections based on content block names, aliases, and anchor text, displayed with dashed underlines in the editor. Hovering shows a preview of the corresponding content block; clicking converts it to a formal block reference. Can be toggled in [Settings - Editor - Virtual Reference]."
				}
			]
		},
		{
			"ID": "20230429115927-coz742f",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20230429115927-coz742f",
				"updated": "20230429115933"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Data repository"
				}
			]
		},
		{
			"ID": "20230429115927-bjmnazr",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115927-bjmnazr",
				"updated": "20230429115945"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Key"
				}
			]
		},
		{
			"ID": "20230429115927-qaqpi8z",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115927-qaqpi8z",
				"updated": "20230429120019"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "The key is used to encrypt data snapshots, "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20220722002536-oh6do47",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "there are three ways to generate"
				},
				{
					"Type": "NodeText",
					"Data": ". It is recommended that ordinary users use passphrase generation. The same passphrase can generate the same key on other devices to facilitate initial data synchronization."
				}
			]
		},
		{
			"ID": "20230429115927-rkshv1l",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115927-rkshv1l",
				"updated": "20230429120027"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Local snapshot"
				}
			]
		},
		{
			"ID": "20230429115927-s5dasq2",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115927-s5dasq2",
				"updated": "20230429115927"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Data snapshots saved locally on the device."
				}
			]
		},
		{
			"ID": "20230429115927-vgz5oj0",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115927-vgz5oj0",
				"updated": "20230429120030"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Locally tagged snapshot"
				}
			]
		},
		{
			"ID": "20230429115927-lhfhnvb",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115927-lhfhnvb",
				"updated": "20230429115927"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Manually tagged snapshots in local snapshots. The purpose of tagging is to facilitate searching, and a meaningful tag name can serve as a sufficient reminder when rolling back a snapshot."
				}
			]
		},
		{
			"ID": "20230429115927-4vr87gi",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115927-4vr87gi",
				"updated": "20230429115927"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Cloud snapshot"
				}
			]
		},
		{
			"ID": "20230429115927-bb5x5s1",
