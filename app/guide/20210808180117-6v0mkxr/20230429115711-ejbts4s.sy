			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Window"
				}
			]
		},
		{
			"ID": "20230429120050-klzguje",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-klzguje",
				"updated": "20230429120050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Tabs can be converted into windows independent of the main interface, and windows can be dragged outside the main interface to avoid overcrowding in the main interface."
				}
			]
		},
		{
			"ID": "20230429120050-zo5u4jx",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-zo5u4jx",
				"updated": "20230429120050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "By pinning the window, the window can also be placed on top of all applications so that the user can make better use of the limited screen space."
				}
			]
		},
		{
			"ID": "20230429120050-36xz5r4",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429120050-36xz5r4",
				"updated": "20230429120050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Layout"
				}
			]
		},
		{
			"ID": "20230429120050-vx2ae03",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-vx2ae03",
				"updated": "20230429120050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "The status of the dock bar, tabs, and panels of the current main interface constitutes the layout, and the layout can be saved and switched in the workspace menu in the upper left corner."
				}
			]
		},
		{
			"ID": "20230429120050-i338ss7",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429120050-i338ss7",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Block icon"
				}
			]
		},
		{
			"ID": "20230429120050-9yrwodu",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-9yrwodu",
				"updated": "20230429120050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Icons appearing in front of blocks, and block labels appearing in the panel support opening the floating preview window by hovering the mouse in most cases, such as the block labels in the outline panel and anti-link panel."
				}
			]
		},
		{
			"ID": "20230429120050-7kwyta0",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-7kwyta0",
				"updated": "20250115151002"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In addition to the floating preview, the block label also supports "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Ctrl"
				},
				{
					"Type": "NodeText",
					"Data": "​+"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Click"
				},
				{
					"Type": "NodeText",
					"Data": "​ to open in the tab, which is especially useful in scenarios such as anti-link panels that require context jumping."
				}
			]
		},
		{
			"ID": "20260614111245-do79b2w",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111245-do79b2w",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Bazaar"
				}
			]
		},
		{
			"ID": "20260614111245-ne03z3w",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111245-ne03z3w",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111245-4exrwcd",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111245-4exrwcd",
						"updated": "20260614111245"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A bazaar is a marketplace where goods are traded, originating from Persian."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111245-ts4nqpv",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111245-ts4nqpv",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, the Bazaar is the entry point for browsing and installing community extensions, including five types: themes, icons, plugins, widgets, and templates. Users can search, install, and update directly within the app."
				}
			]
		},
		{
			"ID": "20260614111245-dorazkv",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111245-dorazkv",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Inbox"
				}
			]
		},
		{
			"ID": "20260614111245-mn05zjr",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111245-mn05zjr",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111245-c72qm7a",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111245-c72qm7a",
						"updated": "20260614111245"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "An inbox is a container for temporarily storing information to be processed."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111245-qeay9ky",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111245-qeay9ky",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, the Inbox is a cloud-based quick capture feature. Text is temporarily stored in the cloud via WeChat or API calls, and can later be moved into documents from the Inbox panel. This feature requires a subscription."
				}
			]
		},
		{
			"ID": "20260614111245-qxb6qzw",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111245-qxb6qzw",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Flashcard"
				}
			]
		},
		{
			"ID": "20260614111245-2h7wety",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111245-2h7wety",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111245-rq2epc7",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111245-rq2epc7",
						"updated": "20260614111245"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A flashcard is a card used for memory training, with a question on the front and an answer on the back, scheduled for review using spaced repetition algorithms."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111245-z9ld0j1",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111245-z9ld0j1",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, flashcards are a spaced repetition review feature based on content blocks. Content blocks can be made into flashcards, and the system automatically schedules the next review based on performance."
				}
			]
		},
		{
			"ID": "20260614111245-ejrp4c3",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111245-ejrp4c3",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Command Palette"
				}
			]
		},
		{
			"ID": "20260614111245-fe0kgoy",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111245-fe0kgoy",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111245-8z5dsoc",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111245-8z5dsoc",
						"updated": "20260614111245"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A command palette is a keyboard-driven entry point for quickly accessing application features, where users type keywords to search and execute commands."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111245-8viirmm",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111245-8viirmm",
				"updated": "20260614111245"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, the command palette is invoked with "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "Ctrl+Shift+P"
				},
				{
					"Type": "NodeText",
					"Data": "​, allowing quick execution of operations like opening panels, toggling features, and navigating documents without navigating through menus."
				}
			]
		},
		{
			"ID": "20230429120050-b0r6bh0",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20230429120050-b0r6bh0",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Other"
				}
			]
		},
		{
			"ID": "20230429120050-s4dqqa7",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429120050-s4dqqa7",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Serving"
				}
			]
		},
		{
			"ID": "20230429120050-xn4ri9u",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429120050-xn4ri9u",
				"updated": "20230429120213"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Through the service capabilities provided by the SiYuan kernel "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20201004194026-s8h2cog",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "Use on browser"
				},
				{
					"Type": "NodeText",
					"Data": "."
				}
			]
		},
		{
			"ID": "20260614111257-gh2a33v",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111257-gh2a33v",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Kernel"
				}
			]
		},
		{
			"ID": "20260614111257-erncw1g",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111257-erncw1g",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111257-uo9f96w",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111257-uo9f96w",
						"updated": "20260614111257"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A kernel is the core component of an operating system, responsible for managing processes, memory, device drivers, file systems, and networking, determining system performance and stability."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111257-fuv5t0k",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111257-fuv5t0k",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, the kernel refers to the backend service process that runs after startup, responsible for core functions such as data read/write, index search, and sync backup. The frontend communicates with the kernel via HTTP/WebSocket. The desktop and mobile apps have built-in kernels; Docker deployments run the kernel separately."
				}
			]
		},
		{
			"ID": "20260614111257-dk8jq1u",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111257-dk8jq1u",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Workspace"
				}
			]
		},
		{
			"ID": "20260614111257-eik5zme",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111257-eik5zme",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111257-rt41e11",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111257-rt41e11",
						"updated": "20260614111257"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "A workspace is the data environment for users to work in, similar to a user directory in an operating system."
						}
					]
				}
			]
		},
		{
			"ID": "20260614111257-xrvsdv3",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111257-xrvsdv3",
				"updated": "20260614111257"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "In SiYuan, a workspace is a folder that stores all data, including notebooks, documents, asset files, configurations, and history. Different workspaces are isolated through file system folders, and one workspace can only be served by one kernel process."
				}
			]
		}
	]
}