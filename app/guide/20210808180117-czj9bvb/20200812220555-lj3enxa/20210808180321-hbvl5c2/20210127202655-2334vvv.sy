			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112525-y03qfjw",
				"updated": "20260614112525"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源支持 PDF 文件预览和标注，可在 PDF 中对文字或区域进行标记，并将标注引用复制到文档中，实现文献阅读与笔记写作的双向联动。"
				}
			]
		},
		{
			"ID": "20260614112525-phcs46z",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112525-phcs46z",
				"updated": "20260614112525"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "插入 PDF 资源文件"
				}
			]
		},
		{
			"ID": "20260614112525-4sr0qh0",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112525-4sr0qh0",
				"updated": "20260614112525"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "将 PDF 文件通过编辑器上传插入后，PDF 将放到 assets 文件夹下，并在文档内生成形如 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf)"
				},
				{
					"Type": "NodeText",
					"Data": "​ 的链接。点击该链接可使用思源进行预览。"
				}
			]
		},
		{
			"ID": "20260614112525-ksnhskd",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112525-ksnhskd",
				"updated": "20260614112525"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "超链接页码跳转"
				}
			]
		},
		{
			"ID": "20260614112525-4ls5633",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112525-4ls5633",
				"updated": "20260614112525"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "新页签打开预览 PDF 支持指定页码，需要将链接带上参数 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "page"
				},
				{
					"Type": "NodeText",
					"Data": "​，例如需要跳转到第七页，则将链接编辑为 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf?page=7)"
				},
				{
					"Type": "NodeText",
					"Data": "​。"
				}
			]
		},
