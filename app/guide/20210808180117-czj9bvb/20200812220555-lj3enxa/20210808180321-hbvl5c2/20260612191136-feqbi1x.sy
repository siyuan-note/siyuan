		{
			"ID": "20260704120000-756f755",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260704120000-756f755",
				"updated": "20260704120000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "加上 --asset 可改为搜索资源文件（PDF/Word/Excel/txt 等）的内容索引，用 --ext 按扩展名过滤（可重复）。该模式下 --method 仅支持 0-3，--order-by 取值为 0 相关性降序、1 相关性升序、2 更新升序、3 更新降序。"
				}
			]
		},
		{
			"ID": "20260704120100-88e7f54",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20260704120100-88e7f54",
				"updated": "20260704120100"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "siyuan search \"关键词\" --asset\nsiyuan search \"关键词\" --asset --ext pdf --ext docx\nsiyuan search \"关键词\" --asset --method 3 --order-by 3\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
		{
