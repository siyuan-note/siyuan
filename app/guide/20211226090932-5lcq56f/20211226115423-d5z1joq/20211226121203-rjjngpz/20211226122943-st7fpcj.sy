			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112630-3ty572v",
				"updated": "20260614112630"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源支援 PDF 檔案預覽和標註，可在 PDF 中對文字或區域進行標記，並將標註引用複製到文件中，實現文獻閱讀與筆記寫作的雙向聯動。"
				}
			]
		},
		{
			"ID": "20260614112630-v4stv84",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112630-v4stv84",
				"updated": "20260614112630"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "插入 PDF 資源檔案"
				}
			]
		},
		{
			"ID": "20260614112630-i5b6hmx",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112630-i5b6hmx",
				"updated": "20260614112630"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "將 PDF 檔案通過編輯器上傳插入後，PDF 將放到 assets 檔案夾下，並在文件內生成形如 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf)"
				},
				{
					"Type": "NodeText",
					"Data": "​ 的連結。點擊該連結可使用思源進行預覽。"
				}
			]
		},
		{
			"ID": "20260614112630-841zxea",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
