			"ID": "20260614112630-fzhcdxl",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112630-fzhcdxl",
				"updated": "20260614112630"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "新頁籤打開預覽 PDF 支援指定頁碼，需要將連結帶上參數 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "page"
				},
				{
					"Type": "NodeText",
					"Data": "​，例如需要跳轉到第七頁，則將連結編輯為 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf?page=7)"
				},
				{
					"Type": "NodeText",
					"Data": "​。"
				}
			]
		},
