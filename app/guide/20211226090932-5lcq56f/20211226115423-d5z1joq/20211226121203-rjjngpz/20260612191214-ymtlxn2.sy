		{
			"ID": "20260704120000-3cf9f66",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260704120000-3cf9f66",
				"updated": "20260704120000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "加上 --asset 可改為搜尋資源檔案（PDF/Word/Excel/txt 等）的內容索引，用 --ext 按副檔名過濾（可重複）。該模式下 --method 僅支援 0-3，--order-by 取值為 0 相關性降序、1 相關性升序、2 更新升序、3 更新降序。"
				}
			]
		},
		{
			"ID": "20260704120100-3d6f0e1",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20260704120100-3d6f0e1",
				"updated": "20260704120100"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "siyuan search \"關鍵字\" --asset\nsiyuan search \"關鍵字\" --asset --ext pdf --ext docx\nsiyuan search \"關鍵字\" --asset --method 3 --order-by 3\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
		{
			"ID": "20260704130000-3c2a405",
