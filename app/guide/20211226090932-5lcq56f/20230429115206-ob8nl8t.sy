							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "導出預覽：轉換為標準 Markdown 後進行預覽"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20230429115509-rl1jlhc",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115509-rl1jlhc",
				"updated": "20250115163209"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "所見即所得和導出預覽模式切換位於編輯器右上角 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ 菜單中；所見即所得編輯和只讀模式切換位於頂欄右上角。"
				}
			]
		},
		{
			"ID": "20260614111457-7uftgv5",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111457-7uftgv5",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "區塊參照"
				}
			]
		},
		{
			"ID": "20260614111457-blivagz",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111457-blivagz",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111457-8a6a678",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111457-8a6a678",
						"updated": "20260614111457"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "參照是指向另一處內容的連結，使讀者可以跳轉到被參照的位置。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111457-el5qnm3",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111457-el5qnm3",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，區塊參照是透過 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "(("
				},
				{
					"Type": "NodeText",
					"Data": "​ 觸發的指向另一個內容塊的連結，支援靜態錨文字和動態錨文字兩種方式。點擊區塊參照可跳轉到被參照的塊，懸浮可預覽。"
				}
			]
		},
		{
			"ID": "20260614111457-nf8wq3v",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111457-nf8wq3v",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "反鏈"
				}
			]
		},
		{
			"ID": "20260614111457-6dfbm0o",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111457-6dfbm0o",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111457-1ad7mbw",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111457-1ad7mbw",
						"updated": "20260614111457"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "反向連結（Backlink）是指其他頁面中指向當前頁面的連結，是雙向連結體系的重要組成部分。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111457-rizqw9m",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111457-rizqw9m",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，反鏈面板展示了所有參照了當前塊的塊。反鏈分為兩部分：連結（透過區塊參照直接關聯）和提及（透過文字匹配的潛在關聯）。"
				}
			]
		},
		{
			"ID": "20260614111457-wh2unuw",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111457-wh2unuw",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "提及"
				}
			]
		},
		{
			"ID": "20260614111457-s49hyaw",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111457-s49hyaw",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111457-sjjoek5",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111457-sjjoek5",
						"updated": "20260614111457"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "提及（Mention）是指在文字中發現的關鍵詞匹配，用於發現潛在的關聯關係。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111457-6pg0dna",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111457-6pg0dna",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，提及類似反鏈中的連結部分，但不是透過區塊參照建立的，而是透過搜尋內容塊名稱、別名和參照錨文字來自動匹配的文字內容。提及可一鍵轉換為區塊參照。"
				}
			]
		},
		{
			"ID": "20260614111457-xqubcvr",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111457-xqubcvr",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "虛擬參照"
				}
			]
		},
		{
			"ID": "20260614111457-8yf6tx8",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111457-8yf6tx8",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111457-javkesq",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111457-javkesq",
						"updated": "20260614111457"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "虛擬參照是一種自動發現潛在參照關係的技術，無需使用者手動建立即可在文字中標識可能存在關聯的內容塊。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111457-xntm6ad",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111457-xntm6ad",
				"updated": "20260614111457"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，虛擬參照基於內容塊的命名、別名和錨文字進行自動探測，在編輯器中以虛線底線標識。滑鼠懸浮可預覽對應的內容塊，點擊可轉換為正式的區塊參照。可在 [設定 - 編輯器 - 虛擬引用] 中開啟或關閉。"
				}
			]
		},
		{
			"ID": "20230429115527-wfbg55f",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20230429115527-wfbg55f",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "資料倉庫"
				}
			]
		},
		{
			"ID": "20230429115527-yhcnfl4",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115527-yhcnfl4",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "密鑰"
				}
			]
		},
		{
			"ID": "20230429115527-mm605dn",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-mm605dn",
				"updated": "20230429115611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "密鑰用於加密資料快照，"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20220722002508-jixu469",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "有三種生成方式"
				},
				{
					"Type": "NodeText",
					"Data": "。建議普通用戶使用密碼短語生成，相同的密碼短語可在其他設備上生成相同的密鑰，以方便初始化資料同步。"
				}
			]
		},
