			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "間隔重複分頁"
				}
			]
		},
		{
			"ID": "20230429115527-aw8shk7",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-aw8shk7",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "將間隔重複界面在分頁中打開。"
