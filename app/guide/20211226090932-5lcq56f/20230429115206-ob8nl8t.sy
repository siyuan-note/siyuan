		},
		{
			"ID": "20230429115527-xozwhac",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-xozwhac",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "分頁可以轉換為獨立於主界面的窗口，窗口可以拖到主界面之外，避免主界面中過於擁擠。"
				}
			]
		},
		{
			"ID": "20230429115527-aflpo8c",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-aflpo8c",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "通過釘住窗口還可以實現該窗口位於所有應用程序之上，以便用戶更好的利用有限的螢幕空間。"
				}
			]
		},
		{
			"ID": "20230429115527-89940fz",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115527-89940fz",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "佈局"
				}
			]
		},
		{
			"ID": "20230429115527-a6wzl4m",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-a6wzl4m",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "當前主界面的停靠欄、分頁和面板的狀態組成了佈局，佈局可以在左上角工作空間菜單中進行保存和切換。"
				}
			]
		},
		{
			"ID": "20230429115527-jjq4vik",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20230429115527-jjq4vik",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "塊標"
				}
			]
		},
		{
			"ID": "20230429115527-1ghs629",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-1ghs629",
				"updated": "20230429115527"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "出現在塊前面的感測器，面板中出現的塊標在大部分情況下都支持通過鼠標懸浮打開預覽浮窗，比如大綱面板、反連面板中的塊標。"
				}
			]
		},
		{
			"ID": "20230429115527-o2we8gd",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115527-o2we8gd",
				"updated": "20250115163227"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "塊標除了懸浮預覽，還支持 "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Ctrl"
				},
				{
					"Type": "NodeText",
					"Data": "​+"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "點擊"
				},
				{
					"Type": "NodeText",
					"Data": "​ 在分頁中打開，這在反連面板等需要跳轉上下文的場景中尤其有用。"
				}
			]
		},
		{
			"ID": "20260614111508-hyrjbqs",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111508-hyrjbqs",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "集市"
				}
			]
		},
		{
			"ID": "20260614111508-fegr1zs",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111508-fegr1zs",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111508-qr2z8cv",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111508-qr2z8cv",
						"updated": "20260614111508"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "集市（Bazaar）源自波斯語，指集中進行商品交易的場所。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111508-asmiekc",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111508-asmiekc",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，集市是瀏覽和安裝社群擴充的入口，包括主題、圖示、外掛、小工具和範本五種類型。使用者可直接在應用內搜尋、安裝和更新。"
				}
			]
		},
		{
			"ID": "20260614111508-h3us19q",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111508-h3us19q",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "收集箱"
				}
			]
		},
		{
			"ID": "20260614111508-5zfdv6g",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111508-5zfdv6g",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111508-2euyh9e",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111508-2euyh9e",
						"updated": "20260614111508"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "收集箱（Inbox）是臨時存放待處理資訊的容器。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111508-ygdjeul",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111508-ygdjeul",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，收集箱是雲端快速記錄功能，透過 WeChat 發送或 API 呼叫將文字暫存到雲端，之後可在收集箱面板中將其移動到文件中進行整理。該功能需要訂閱會員。"
				}
			]
		},
		{
			"ID": "20260614111508-7otqkx3",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111508-7otqkx3",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "閃卡"
				}
			]
		},
		{
			"ID": "20260614111508-zw53p6s",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111508-zw53p6s",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111508-q89u31h",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111508-q89u31h",
						"updated": "20260614111508"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "閃卡（Flashcard）是一種用於記憶訓練的卡片，正面寫問題，背面寫答案，透過間隔重複演算法安排複習時間。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111508-sef3t3q",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111508-sef3t3q",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，閃卡是基於內容塊的間隔重複複習功能。可將內容塊製作為閃卡，系統根據複習表現自動安排下次複習時間。"
				}
			]
		},
		{
			"ID": "20260614111508-gqxf0f5",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111508-gqxf0f5",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "命令面板"
				}
			]
		},
		{
			"ID": "20260614111508-u5rg5cf",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111508-u5rg5cf",
				"updated": "20260614111508"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111508-4nzluhc",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111508-4nzluhc",
						"updated": "20260614111508"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "命令面板（Command Palette）是一種透過鍵盤快速存取應用功能的入口，使用者輸入關鍵詞即可搜尋和執行命令。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111508-3gu2eju",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111508-3gu2eju",
				"updated": "20260614111508"
			},
			"Children": [
				{
