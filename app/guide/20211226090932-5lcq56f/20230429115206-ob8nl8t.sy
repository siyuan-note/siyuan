			"Children": [
				{
					"Type": "NodeText",
					"Data": "內核"
				}
			]
		},
		{
			"ID": "20260614111516-ms7zh4q",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111516-ms7zh4q",
				"updated": "20260614111516"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111516-guzmn5l",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111516-guzmn5l",
						"updated": "20260614111516"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "內核是作業系統的核心元件，負責管理系統的進程、記憶體、裝置驅動程式、檔案和網路系統等，決定著系統的效能和穩定性。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111516-jaeybfl",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111516-jaeybfl",
				"updated": "20260614111516"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，內核指的是啟動後執行的後端服務進程，負責資料讀寫、索引搜尋、同步備份等核心功能。前端介面透過 HTTP/WebSocket 與內核通訊。桌面端和行動端內建內核，Docker 部署時單獨執行內核。"
				}
			]
		},
		{
			"ID": "20260614111516-xaresom",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111516-xaresom",
				"updated": "20260614111516"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "工作空間"
				}
			]
		},
		{
			"ID": "20260614111516-264i0vw",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111516-264i0vw",
				"updated": "20260614111516"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111516-8ttqwlt",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111516-8ttqwlt",
						"updated": "20260614111516"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "工作空間是使用者進行工作時的資料環境，類似於作業系統中的使用者目錄。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111516-bb2sqqp",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111516-bb2sqqp",
				"updated": "20260614111516"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "在思源中，工作空間是一個資料夾，用於儲存所有資料，包括筆記本、文件、資源檔案、設定和歷史記錄等。不同工作空間透過檔案系統資料夾相互隔離，一個工作空間只能被一個內核進程伺服。"
				}
			]
		}
	]
}