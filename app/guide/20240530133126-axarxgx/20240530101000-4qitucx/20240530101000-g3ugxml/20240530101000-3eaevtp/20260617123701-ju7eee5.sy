			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "テンプレート計算は「テンプレートスニペット」と同じ Go テンプレート構文を使用し、区切り文字は "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": ".action{"
				},
				{
					"Type": "NodeText",
					"Data": "​ "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "}"
				},
				{
					"Type": "NodeText",
					"Data": "​、関数は "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "a",
					"TextMarkAHref": "http://masterminds.github.io/sprig/",
					"TextMarkTextContent": "sprig"
				},
				{
					"Type": "NodeText",
					"Data": " 仕様に従います。詳細は "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20240530101000-6x9ivi7",
					"TextMarkBlockRefSubtype": "d",
					"TextMarkTextContent": "テンプレートスニペット"
				},
				{
					"Type": "NodeText",
					"Data": " を参照してください。"
				}
			]
		},
