		"title": "PDF 注釈",
		"type": "doc",
		"updated": "20260614112612"
	},
	"Children": [
		{
			"ID": "20260614112611-ydoehak",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112611-ydoehak",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "概要"
				}
			]
		},
		{
			"ID": "20260614112611-0wtch1l",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112611-0wtch1l",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源はPDFファイルのプレビューと注釈をサポートしています。PDF内のテキストや領域にマークを付け、注釈参照をドキュメントにコピーすることで、文献読書とノート作成の双方向連携を実現します。"
				}
			]
		},
		{
			"ID": "20260614112611-gzxk32l",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112611-gzxk32l",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "PDFアセットの挿入"
				}
			]
		},
		{
			"ID": "20260614112611-stw592m",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112611-stw592m",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "PDFファイルをエディタからアップロードして挿入すると、PDFはassetsフォルダに配置され、ドキュメント内に "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf)"
				},
				{
					"Type": "NodeText",
					"Data": "​ 形式のリンクが生成されます。リンクをクリックすると思源でプレビューできます。"
				}
			]
		},
		{
			"ID": "20260614112611-t6idhna",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112611-t6idhna",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ハイパーリンクページジャンプ"
				}
			]
		},
		{
			"ID": "20260614112611-he6z12e",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112611-he6z12e",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "新しいタブでPDFプレビューを開く際、リンクに "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "page"
				},
				{
					"Type": "NodeText",
					"Data": "​ パラメータを追加することでページを指定できます。例えば7ページ目にジャンプするには、リンクを "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "[filename](assets/filename.pdf?page=7)"
				},
				{
					"Type": "NodeText",
					"Data": "​ に編集します。"
				}
			]
		},
		{
			"ID": "20260614112611-0hlnngu",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614112611-0hlnngu",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "注釈"
				}
			]
		},
		{
			"ID": "20260614112611-fnnkdp6",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112611-fnnkdp6",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "PDFプレビューでテキストや領域に注釈を付け、注釈参照をドキュメントにコピーして、読書とノート作成をシームレスに連携できます。"
				}
			]
		},
		{
			"ID": "20260614112611-i11y4bf",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614112611-i11y4bf",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "注釈の作成"
				}
			]
		},
