						"updated": "20260614112611"
					},
					"Children": [
						{
							"ID": "20260614112611-7iawm45",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20260614112611-7iawm45",
								"updated": "20260614112611"
							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "テキスト選択ハイライト"
								},
								{
									"Type": "NodeText",
									"Data": "：PDF内でテキストを選択し、ポップアップのカラーツールバーから色をクリックすると、半透明のハイライトが追加されます。同時に注釈参照テキストが自動的にクリップボードにコピーされ、ドキュメントに直接貼り付けて参照リンクとして利用できます"
								}
							]
						}
					]
				},
				{
					"ID": "20260614112611-03wopqi",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20260614112611-03wopqi",
						"updated": "20260614112611"
					},
					"Children": [
						{
							"ID": "20260614112611-q2oooxk",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20260614112611-q2oooxk",
								"updated": "20260614112611"
							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "矩形領域注釈"
								},
								{
									"Type": "NodeText",
									"Data": "：PDFツールバーの領域注釈ボタンをクリックし、PDFページ上でドラッグして矩形を描画します。二つのスタイル（背景色付きの塗りつぶし矩形と境界線のみの矩形）をサポートし、注釈メニューのスタイル切替ボタンで切り替えられます"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20260614112611-k351we9",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614112611-k351we9",
				"updated": "20260614112611"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "注釈は7種類のプリセットカラーをサポートします。注釈データはPDFと同じディレクトリに、PDFと同名の "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": ".sya"
				},
				{
					"Type": "NodeText",
					"Data": "​ ファイルとして自動的に保存されます。"
				}
			]
		},
