			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "コンテンツブロックをフラッシュカードとして設定すると、システムは間隔反復アルゴリズムFSRS（github repo: open-spaced-repetition/free-spaced-repetition-scheduler）によって自動的に復習をスケジュールし、忘却の臨界点で復習を促して短期記憶を長期記憶に変換します。"
				}
			]
		},
		{
			"ID": "20260614194342-wa0impz",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614194342-wa0impz",
				"updated": "20260614194354"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "使用方法"
				}
			]
		},
