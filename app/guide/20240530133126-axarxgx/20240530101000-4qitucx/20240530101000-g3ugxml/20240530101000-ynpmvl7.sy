		{
			"ID": "20260614194342-ulwyhdw",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614194342-ulwyhdw",
				"updated": "20260614194342"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "答えを表示した後、スペースとEnterでも「良い」評価を直接トリガーできます。評価はカードの復習間隔に直接影響します——高い評価は次回復習までの時間を延長し、低い評価は短縮します。システムはFSRSアルゴリズムを使用して、各ユーザーの評価履歴に基づいて復習スケジュールを自動的に最適化します。"
				}
			]
		},
		{
			"ID": "20260614194342-lme1lzb",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
