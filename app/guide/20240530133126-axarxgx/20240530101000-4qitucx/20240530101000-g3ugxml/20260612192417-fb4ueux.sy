			"Properties": {
				"id": "20260618123956-pd10a68",
				"updated": "20260618123956"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "CLI の実行ファイルは "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "&lt;インストールディレクトリ&gt;/resources/kernel/SiYuan-Kernel"
				},
				{
					"Type": "NodeText",
					"Data": "​ で、"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan"
				},
				{
					"Type": "NodeText",
					"Data": "​ コマンドで呼び出せます。"
				}
			]
		},
		{
			"ID": "20260618123956-6xjq4tq",
			"Type": "NodeList",
			"ListData": {},
			"Properties": {
