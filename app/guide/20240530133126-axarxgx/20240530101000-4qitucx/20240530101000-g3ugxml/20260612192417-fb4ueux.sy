		{
			"ID": "20260704120000-f2bb53c",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260704120000-f2bb53c",
				"updated": "20260704120000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "--asset を付けるとアセットファイル（PDF/Word/Excel/txt など）の内容インデックスを検索します。--ext で拡張子による絞り込みが可能（繰り返し可）。このモードの --method は 0-3 のみ対応、--order-by は 0 関連度降順、1 関連度昇順、2 更新昇順、3 更新降順です。"
				}
			]
		},
		{
			"ID": "20260704120100-612c7e7",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20260704120100-612c7e7",
				"updated": "20260704120100"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "siyuan search \"キーワード\" --asset\nsiyuan search \"キーワード\" --asset --ext pdf --ext docx\nsiyuan search \"キーワード\" --asset --method 3 --order-by 3\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
		{
			"ID": "20260704130000-82aecd4",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260704130000-82aecd4",
				"updated": "20260704130000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "--get-asset を付けると、パスで単一アセットファイルの全文インデックス内容を取得します（位置引数がパスとして扱われます、例: assets/report.pdf）。--asset 検索で見つけたファイルの全文を取得するのに便利です。"
				}
			]
		},
