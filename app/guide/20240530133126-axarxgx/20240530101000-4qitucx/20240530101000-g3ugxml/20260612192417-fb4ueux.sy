					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan [グローバルフラグ] \u0026lt;コマンド\u0026gt; [パラメータ]"
				},
				{
					"Type": "NodeText",
					"Data": "​"
				}
			]
		},
