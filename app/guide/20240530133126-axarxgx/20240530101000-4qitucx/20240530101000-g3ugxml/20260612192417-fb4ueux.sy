			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan [グローバルフラグ] &lt;コマンド&gt; [パラメータ]"
				},
				{
					"Type": "NodeText",
					"Data": "​"
				}
			]
		},
