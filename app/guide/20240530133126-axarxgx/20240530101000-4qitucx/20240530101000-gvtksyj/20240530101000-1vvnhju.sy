			"Children": [
				{
					"Type": "NodeText",
					"Data": "埋め込みコンテンツブロックは、主にコンテンツブロックを集約するために使用します。SQL スクリプトを "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "{{"
				},
				{
					"Type": "NodeText",
					"Data": "​ と "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "}}"
				},
				{
					"Type": "NodeText",
					"Data": "​ で囲み、ワンライナーで "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "{{ SELECT * FROM blocks WHERE content LIKE '%キーワード%' }}"
				},
				{
					"Type": "NodeText",
					"Data": "​ のように記述します。フィールドの詳細は、"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20240530101000-dgjyf1m",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "こちら"
				},
				{
					"Type": "NodeText",
					"Data": "を参照してください。"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "コンテンツブロック/埋め込み"
				},
				{
