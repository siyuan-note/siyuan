		{
			"ID": "20260613174259-xv3y31i",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260613174259-xv3y31i",
				"updated": "20260613174259"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ショートハンドはモバイル端末でのクイックキャプチャ機能です。ひらめきや一時的な情報を記録したいとき、思源を開いてドキュメント編集に入らなくても、システム共有やショートカットからテキストを素早く保存できます。ショートハンドの内容は一時的にローカルに保存され、その後自動的にドキュメントパネルに取り込まれて整理されます。"
				}
			]
		},
		{
			"ID": "20260613174259-djgqfrn",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
