				"id": "20240530101000-jvis6t0",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "概要"
				}
			]
		},
		{
			"ID": "20240530101000-dsq1inp",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-0czawoj",
				"id": "20240530101000-dsq1inp",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan では一部に複雑な専門用語が使用されているため、分かりにくい箇所があるかもしれません。本章ではこれらの用語をひとつずつ解説し、SiYuan の理解と活用を深めていただくことを目指します。"
				}
			]
		},
		{
			"ID": "20240530101000-yhf1b7l",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-5te4ctj",
				"id": "20240530101000-yhf1b7l",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "注意事項"
				},
				{
					"Type": "NodeText",
					"Data": "​: 具体的な機能はデスクトップ版を例に紹介します。"
				}
			]
		},
		{
			"ID": "20240530101000-fidycup",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"ID": "20240530101000-232agxh",
				"id": "20240530101000-fidycup",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "エディタ"
				}
			]
		},
		{
			"ID": "20240530101000-xrjohag",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"ID": "20240530101000-7h710cb",
				"id": "20240530101000-xrjohag",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "パンくずリスト"
				}
			]
		},
		{
			"ID": "20240530101000-6wzp9bk",
			"Type": "NodeBlockquote",
			"Properties": {
				"ID": "20240530101000-2b9mh4i",
				"id": "20240530101000-6wzp9bk",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20240530101000-0fplbka",
					"Type": "NodeParagraph",
					"Properties": {
						"ID": "20240530101000-i4qhols",
						"id": "20240530101000-0fplbka",
						"updated": "20240530101000"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "パンくずリストは、アプリケーションのナビゲーションを補助する要素で、通常ページ上部の水平列に表示されます。ユーザーの現在位置までのパスを示し、ナビゲーション中の便利な手がかりと方向感を提供します。これにより、ユーザーはサイトの構造をより把握しやすくなり、前のページや上位ページへの素早い移動が可能になり、無駄なクリックや迷子になる可能性が減ります。パンくずリストはユーザーエクスペリエンス設計の一部として、アプリケーションの使いやすさと操作性を向上させる役割を果たします。"
						}
					]
				}
			]
		},
		{
			"ID": "20240530101000-mwlyp22",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-no1adfs",
				"id": "20240530101000-mwlyp22",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan でのパンくずリストはエディタ上部に右矢印で繫がれたブロックのパスを指し、ブロック構造内でのナビゲーションに使われます。各階層はブロックアイコンで始まり、アイコンにマウスカーソルを合わせるとフローティングウィンドウでプレビューが開きます。"
				}
			]
		},
		{
			"ID": "20240530101000-qgxgqf9",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"ID": "20240530101000-7x1rsjj",
				"id": "20240530101000-qgxgqf9",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "アンカーテキスト"
				}
			]
		},
		{
			"ID": "20240530101000-ep8q9yc",
			"Type": "NodeBlockquote",
			"Properties": {
				"ID": "20240530101000-8err3nm",
				"id": "20240530101000-ep8q9yc",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20240530101000-cb9gqhn",
					"Type": "NodeParagraph",
					"Properties": {
						"ID": "20240530101000-m7ss1sf",
						"id": "20240530101000-cb9gqhn",
						"updated": "20240530101000"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "アンカーテキストは、ハイパーリンク内でクリックされるテキスト部分のことを指し、通常は青色で表示されます。アンカーテキストは、ハイパーリンクの URL アドレスと関連付けられており、ユーザーがアンカーテキストをクリックすると、対応する Web ページやファイルに自動的に移動します。アンカーテキストは任意の文字やフレーズを使用できますが、通常はリンク先のコンテンツに関連するもので、一般的には移動先のコンテンツのタイトルが使われます。"
						}
					]
				}
			]
		},
		{
			"ID": "20240530101000-f0sz19e",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-ue7k9hj",
				"id": "20240530101000-f0sz19e",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan では通常のハイパーリンク要素に加えて、ブロック参照や PDF 注釈の参照要素にもアンカーテキストの概念を拡張しています。特に、ブロック参照要素のアンカーテキストは、静的アンカーテキストと動的アンカーテキストに分けられます。詳しくは、"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20240530101000-k5rp4xa",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "コンテンツブロックのアンカーテキストセクション"
				},
				{
					"Type": "NodeText",
					"Data": "を参照してください。"
				}
			]
		},
		{
			"ID": "20240530101000-urpx8am",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
