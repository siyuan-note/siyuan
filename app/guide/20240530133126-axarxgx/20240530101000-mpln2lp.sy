					"Properties": {
						"id": "20260614111431-0es045w",
						"updated": "20260614111431"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "バザール（Bazaar）はペルシャ語に由来し、商品取引が行われる場所を指します。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111431-f1sre8s",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111431-f1sre8s",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、バザールはコミュニティ拡張機能の閲覧とインストールの入り口です。テーマ、アイコン、プラグイン、ウィジェット、テンプレートの5種類があります。アプリ内で直接検索、インストール、更新が可能です。"
				}
			]
		},
		{
			"ID": "20260614111431-lt22acr",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111431-lt22acr",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "受信トレイ"
				}
			]
		},
		{
			"ID": "20260614111431-hf09vm3",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111431-hf09vm3",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
