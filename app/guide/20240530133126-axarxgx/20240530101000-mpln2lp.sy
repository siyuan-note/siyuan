		},
		{
			"ID": "20240530101000-r6ymde7",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-zanjben",
				"id": "20240530101000-r6ymde7",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan カーネルが提供するサービス機能を利用して"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20240530101000-40hohog",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "ブラウザで使用"
				},
				{
					"Type": "NodeText",
					"Data": "できます。"
				}
			]
		},
		{
			"ID": "20260614111442-uzd7ap4",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111442-uzd7ap4",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "カーネル"
				}
			]
		},
		{
			"ID": "20260614111442-r76ira9",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111442-r76ira9",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111442-t5qeayt",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111442-t5qeayt",
						"updated": "20260614111442"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "カーネルはオペレーティングシステムの中核コンポーネントであり、プロセス、メモリ、デバイスドライバ、ファイルシステム、ネットワークなどを管理し、システムのパフォーマンスと安定性を決定します。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111442-xfcnmf9",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111442-xfcnmf9",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、カーネルは起動後に実行されるバックエンドサービスプロセスを指し、データの読み書き、インデックス検索、同期バックアップなどの中核機能を担当します。フロントエンドは HTTP/WebSocket でカーネルと通信します。デスクトップ版とモバイル版にはカーネルが内蔵されており、Dockerデプロイではカーネルを個別に実行します。"
				}
			]
		},
		{
			"ID": "20260614111442-1h0w47v",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111442-1h0w47v",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ワークスペース"
				}
			]
		},
		{
			"ID": "20260614111442-ykut5zd",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111442-ykut5zd",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111442-rr22ro5",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111442-rr22ro5",
						"updated": "20260614111442"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "ワークスペースは、ユーザーが作業するためのデータ環境であり、オペレーティングシステムのユーザーディレクトリに似ています。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111442-2c8f039",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111442-2c8f039",
				"updated": "20260614111442"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、ワークスペースはすべてのデータを保存するフォルダです。ノートブック、ドキュメント、アセットファイル、設定、履歴などが含まれます。異なるワークスペースはファイルシステムのフォルダによって分離され、1つのワークスペースは1つのカーネルプロセスのみがサーブできます。"
				}
			]
		}
	]
}