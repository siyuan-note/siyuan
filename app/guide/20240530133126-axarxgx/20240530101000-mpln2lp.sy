				"id": "20240530101000-pwg15ok",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "現在のインターフェースのドック、タブ、パネルの状態がレイアウトを構成し、メインメニューの "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "レイアウト"
				},
				{
					"Type": "NodeText",
					"Data": "​ から保存と切り替えができます。"
				}
			]
		},
		{
			"ID": "20240530101000-b4l3ltr",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"ID": "20240530101000-n230loy",
				"id": "20240530101000-b4l3ltr",
				"updated": "20250115163249"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ブロックアイコン"
				}
			]
		},
		{
			"ID": "20240530101000-91br7eq",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-au8qnky",
				"id": "20240530101000-91br7eq",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ブロックにマウスカーソルを合わせると左側に表示されるアイコンです。パネル (アウトラインパネル、バックリンクパネルなど) に表示されるブロックアイコンにマウスカーソルを合わせると、フローティングウィンドウでプレビューが開かれます。"
				}
			]
		},
		{
			"ID": "20240530101000-0svfhj0",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20240530101000-0svfhj0",
				"updated": "20250115163249"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ブロックアイコンにマウスカーソルを合わせると表示されるプレビューに加えて、"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Ctrl"
				},
				{
					"Type": "NodeText",
					"Data": "​+"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "クリック"
				},
				{
					"Type": "NodeText",
					"Data": "​ でタブを開くこともできます。これは、バックリンクパネルからコンテキストに移動する場合に便利です。"
				}
			]
		},
		{
			"ID": "20240530101000-9mcnl5p",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
