					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111431-xhi7168",
						"updated": "20260614111431"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "受信トレイ（Inbox）は、処理待ちの情報を一時的に保管するコンテナです。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111431-rtrcw9g",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111431-rtrcw9g",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、受信トレイはクラウドベースのクイックキャプチャ機能です。WeChat送信やAPI呼び出しでテキストをクラウドに一時保存し、後で受信トレイパネルからドキュメントに移動して整理できます。この機能にはサブスクリプションが必要です。"
				}
			]
		},
		{
			"ID": "20260614111431-4r2ugxx",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111431-4r2ugxx",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "フラッシュカード"
				}
			]
		},
		{
			"ID": "20260614111431-nhrve6j",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111431-nhrve6j",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111431-56kdl5g",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111431-56kdl5g",
						"updated": "20260614111431"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "フラッシュカード（Flashcard）は、記憶トレーニングに使用されるカードで、表面に問題、裏面に答えが書かれ、間隔反復アルゴリズムで復習スケジュールが決められます。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111431-elxwoq9",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111431-elxwoq9",
				"updated": "20260614111431"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、フラッシュカードはコンテンツブロックに基づく間隔反復復習機能です。コンテンツブロックをフラッシュカードとして作成でき、システムは復習のパフォーマンスに基づいて次回の復習時間を自動的にスケジュールします。"
				}
			]
		},
		{
			"ID": "20260614111431-r7qhatv",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
