			"Children": [
				{
					"Type": "NodeText",
					"Data": "タブ上の右クリックメニューから "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "新しいウィンドウに移動"
				},
				{
					"Type": "NodeText",
					"Data": "​ を選ぶことで、メインインターフェースから独立したウィンドウに変換できます。"
				}
			]
		},
		{
			"ID": "20240530101000-sjijinn",
			"Type": "NodeParagraph",
			"Properties": {
				"ID": "20240530101000-38efo4p",
				"id": "20240530101000-sjijinn",
