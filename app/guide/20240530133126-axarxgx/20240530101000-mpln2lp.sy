			]
		},
		{
			"ID": "20240530101000-17rtvfz",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20240530101000-17rtvfz",
				"updated": "20240530101000"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "編集モードと読み取りモードの切り替えはエディタ右上の "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ メニューから行います。"
				}
			]
		},
		{
			"ID": "20260614111408-vk0xmpd",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111408-vk0xmpd",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "ブロック参照"
				}
			]
		},
		{
			"ID": "20260614111408-qzyyj71",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111408-qzyyj71",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111408-bmw1qqx",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111408-bmw1qqx",
						"updated": "20260614111408"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "参照とは別の場所のコンテンツへのリンクであり、読者を参照先へジャンプさせることができます。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111408-9gv28yr",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111408-9gv28yr",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、ブロック参照は "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "(("
				},
				{
					"Type": "NodeText",
					"Data": "​ でトリガーされる別のコンテンツブロックへのリンクです。静的アンカーテキストと動的アンカーテキストの両方をサポートします。ブロック参照をクリックすると参照先のブロックにジャンプし、ホバーするとプレビューが表示されます。"
				}
			]
		},
		{
			"ID": "20260614111408-sm0q0gi",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111408-sm0q0gi",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "バックリンク"
				}
			]
		},
		{
			"ID": "20260614111408-qny0eh7",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111408-qny0eh7",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111408-4e5mgm4",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111408-4e5mgm4",
						"updated": "20260614111408"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "バックリンク（Backlink）とは、他のページから現在のページへのリンクであり、双方向リンクシステムの重要な要素です。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111408-qpnxtl5",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111408-qpnxtl5",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、バックリンクパネルに現在のブロックを参照しているすべてのブロックが表示されます。バックリンクはリンク（ブロック参照による直接的な関連付け）とメンション（テキストマッチングによる潜在的な関連付け）の2つの部分で構成されます。"
				}
			]
		},
		{
			"ID": "20260614111408-aut68xk",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111408-aut68xk",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "メンション"
				}
			]
		},
		{
			"ID": "20260614111408-b4jqt4a",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111408-b4jqt4a",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111408-f6b9b0i",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111408-f6b9b0i",
						"updated": "20260614111408"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "メンション（Mention）とは、テキスト内で発見されたキーワードマッチングであり、潜在的な関連関係を発見するために使用されます。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111408-eyflmhq",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111408-eyflmhq",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、メンションはバックリンクのリンク部分と似ていますが、ブロック参照で確立されるのではなく、コンテンツブロック名、エイリアス、参照アンカーテキストを検索して自動的にマッチングされたテキストコンテンツです。メンションはワンクリックでブロック参照に変換できます。"
				}
			]
		},
		{
			"ID": "20260614111408-8a0yvi6",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614111408-8a0yvi6",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "仮想参照"
				}
			]
		},
		{
			"ID": "20260614111408-aupje3s",
			"Type": "NodeBlockquote",
			"Properties": {
				"id": "20260614111408-aupje3s",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeBlockquoteMarker",
					"Data": "\u003e"
				},
				{
					"ID": "20260614111408-4qsmcdm",
					"Type": "NodeParagraph",
					"Properties": {
						"id": "20260614111408-4qsmcdm",
						"updated": "20260614111408"
					},
					"Children": [
						{
							"Type": "NodeText",
							"Data": "仮想参照は、手動で作成することなく、関連する可能性のあるコンテンツブロックをテキスト内で自動的に特定する技術です。"
						}
					]
				}
			]
		},
		{
			"ID": "20260614111408-guewqrn",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614111408-guewqrn",
				"updated": "20260614111408"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "思源では、仮想参照はコンテンツブロックの名前、エイリアス、アンカーテキストに基づいて自動的に検出され、エディタでは破線の下線で表示されます。ホバーすると対応するコンテンツブロックのプレビューが表示され、クリックすると正式なブロック参照に変換できます。[設定 - エディタ - 仮想参照] でオン/オフを切り替えられます。"
				}
			]
		},
